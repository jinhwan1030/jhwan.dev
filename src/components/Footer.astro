---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} Jinhwan Jung. All rights reserved.
	<div class="social-links">
		<a href="https://github.com/jinhwan1030" target="_blank" rel="noopener noreferrer">GitHub</a>
		<a href="mailto:saewoo_@naver.com">Email</a>
	</div>
</footer>
<style>
	footer {
		padding: 3rem 1rem 5rem;
		background: var(--color-surface-soft);
		border-top: 1px solid var(--color-line-soft);
		color: var(--color-muted);
		text-align: center;
		font-size: 0.88rem;
	}
	.social-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem;
		margin-top: 1rem;
	}
	.social-links a {
		display: inline-flex;
		align-items: center;
		min-height: 40px;
		padding: 0 0.75rem;
		border: 1px solid var(--color-line);
		border-radius: 9999px;
		text-decoration: none;
		color: var(--color-muted);
		font-weight: 650;
	}
	.social-links a:hover {
		color: var(--color-ink-soft);
		border-color: var(--color-line);
		background: var(--color-surface);
	}
	@media (max-width: 640px) {
		footer {
			padding: 2.5rem 1rem 4rem;
		}
	}
</style>
