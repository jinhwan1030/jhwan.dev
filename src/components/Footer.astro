---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} Jinhwan Jung</p>
	<p class="footer-note">작은 서비스를 만들고 운영합니다.</p>
</footer>
<style>
	footer {
		padding: 3rem 1rem 4.5rem;
		background: var(--color-surface-soft);
		border-top: 1px solid var(--color-line-soft);
		color: var(--color-muted);
		text-align: center;
		font-size: 0.88rem;
	}
	footer p {
		margin: 0;
	}
	.footer-note {
		margin-top: 0.35rem;
		color: var(--color-faint);
		font-size: 0.82rem;
	}
	@media (max-width: 640px) {
		footer {
			padding: 2.5rem 1rem 3.5rem;
		}
	}
</style>
