---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/jinhwan1030" target="_blank" rel="noopener noreferrer">GitHub</a>
			<a href="mailto:saewoo_@naver.com">Email</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		margin: 0;
		padding: 0.7rem 1rem;
		background: rgba(255, 255, 255, 0.88);
		border-bottom: 1px solid var(--color-line-soft);
		backdrop-filter: blur(16px);
	}
	h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 0.98rem;
		letter-spacing: 0;
	}

	h2 a,
	h2 a.active {
		color: var(--color-ink);
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(100%, 1040px);
		margin: 0 auto;
	}
	nav a {
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		padding: 0 0.55rem;
		color: var(--color-muted);
		border-bottom: 2px solid transparent;
		text-decoration: none;
		font-size: 0.88rem;
		font-weight: 650;
		white-space: nowrap;
	}
	nav a.active {
		text-decoration: none;
		color: var(--color-ink);
		border-bottom-color: var(--color-accent);
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.15rem;
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
		gap: 0.1rem;
	}
	@media (max-width: 720px) {
		header {
			padding: 0.45rem 0.65rem;
		}
		nav {
			gap: 0.35rem;
		}
		h2 {
			font-size: 0.84rem;
			flex: 0 0 auto;
		}
		.internal-links {
			flex: 1;
			justify-content: flex-end;
			gap: 0;
			min-width: 0;
		}
		nav a {
			min-height: 36px;
			padding: 0 0.36rem;
			font-size: 0.74rem;
		}
		.social-links {
			display: none;
		}
	}
	@media (max-width: 380px) {
		header {
			padding-inline: 0.5rem;
		}
		h2 {
			font-size: 0.78rem;
		}
		nav a {
			padding-inline: 0.3rem;
			font-size: 0.7rem;
		}
	}
</style>
