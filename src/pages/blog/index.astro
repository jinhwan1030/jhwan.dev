---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const CATEGORY_EMOJI: Record<string, string> = {
  '홈랩': '🖥️',
  'ML/AI': '🤖',
  'Android': '📱',
  '개발': '💻',
  '프로젝트': '🗂️',
  '일상': '✍️',
};

const CATEGORY_COLOR: Record<string, string> = {
  '홈랩': 'linear-gradient(135deg, #334155, #2563eb)',
  'ML/AI': 'linear-gradient(135deg, #2563eb, #0891b2)',
  'Android': 'linear-gradient(135deg, #16a34a, #0891b2)',
  '개발': 'linear-gradient(135deg, #0891b2, #2563eb)',
  '프로젝트': 'linear-gradient(135deg, #0f766e, #2563eb)',
  '일상': 'linear-gradient(135deg, #64748b, #0f766e)',
};

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      body {
        font-family: var(--font-sans);
        background: #ffffff;
        color: var(--color-ink);
      }

      main {
        max-width: var(--page-max);
        margin: 0 auto;
        padding: 4rem 1.5rem;
      }

      .page-label {
        font-size: 0.72rem;
        font-weight: 750;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--color-faint);
        margin-bottom: 0.75rem;
      }

      .page-title {
        font-family: var(--font-display);
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 850;
        color: var(--color-ink);
        margin-bottom: 2.5rem;
        letter-spacing: 0;
      }

      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1.5rem;
      }

      .card {
        border: 1px solid var(--color-line-soft);
        border-radius: var(--radius-lg);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
        display: block;
      }

      .card:hover {
        border-color: var(--color-line);
        box-shadow: var(--shadow-soft);
        transform: translateY(-3px);
      }

      .card-thumb {
        height: 140px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
      }

      .card-body {
        padding: 1.3rem;
      }

      .card-category {
        font-size: 0.72rem;
        font-weight: 750;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-accent);
        margin-bottom: 0.5rem;
      }

      .card-title {
        font-family: var(--font-display);
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--color-ink);
        margin-bottom: 0.55rem;
        line-height: 1.42;
        letter-spacing: 0;
      }

      .card-desc {
        font-size: 0.9rem;
        color: var(--color-muted);
        line-height: 1.65;
        margin-bottom: 1rem;
      }

      .card-date {
        font-size: 0.72rem;
        color: var(--color-faint);
        font-weight: 650;
      }

      @media (max-width: 640px) {
        main {
          padding: 2rem 0.95rem;
        }
        .page-label {
          font-size: 0.66rem;
        }
        .page-title {
          font-size: 1.55rem;
          margin-bottom: 1rem;
        }
        .cards {
          grid-template-columns: 1fr;
          gap: 0.52rem;
        }
        .card {
          display: grid;
          grid-template-columns: 52px 1fr;
          min-height: 82px;
          border-radius: var(--radius-md);
        }
        .card-thumb {
          height: 100%;
          min-height: 82px;
          font-size: 1.28rem;
        }
        .card-body {
          padding: 0.56rem 0.7rem;
          min-width: 0;
        }
        .card-category {
          margin-bottom: 0.2rem;
          font-size: 0.6rem;
        }
        .card-title {
          margin-bottom: 0.22rem;
          font-size: 0.84rem;
          line-height: 1.28;
        }
        .card-desc {
          display: -webkit-box;
          margin-bottom: 0.28rem;
          overflow: hidden;
          -webkit-box-orient: vertical;
          -webkit-line-clamp: 1;
          font-size: 0.72rem;
          line-height: 1.42;
        }
        .card-date {
          font-size: 0.66rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <p class="page-label">Blog</p>
      <h1 class="page-title">글 목록</h1>
      <div class="cards">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="card">
            <div class="card-thumb" style={`background: ${CATEGORY_COLOR[post.data.category] || 'linear-gradient(135deg, #334155, #2563eb)'}`}>
              {CATEGORY_EMOJI[post.data.category] || '💻'}
            </div>
            <div class="card-body">
              <p class="card-category">{post.data.category}</p>
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-desc">{post.data.description}</p>
              <p class="card-date">{post.data.pubDate.toLocaleDateString('ko-KR')}</p>
            </div>
          </a>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>
