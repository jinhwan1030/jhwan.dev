---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      :root {
        --grad-start: #2563eb;
        --grad-mid: #4f46e5;
        --grad-end: #0f766e;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: var(--font-sans);
        background: #ffffff;
        color: var(--color-ink);
        overflow-x: hidden;
      }

      main {
        max-width: var(--page-max);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .hero {
        min-height: min(720px, calc(100svh - 64px));
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 5rem 0 4rem;
      }

      .hero-eyebrow {
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--color-faint);
        margin-bottom: 1.1rem;
        opacity: 0;
        animation: fadeUp 0.6s ease forwards 0.1s;
      }

      .hero-name {
        max-width: 780px;
        font-family: var(--font-display);
        font-size: clamp(2.8rem, 9vw, 6.2rem);
        font-weight: 850;
        line-height: 0.98;
        letter-spacing: 0;
        background: linear-gradient(135deg, var(--grad-start), var(--grad-mid), var(--grad-end));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 1.25rem;
        opacity: 0;
        animation: fadeUp 0.6s ease forwards 0.2s;
      }

      .hero-title {
        max-width: 680px;
        font-size: clamp(1.02rem, 2.2vw, 1.22rem);
        font-weight: 450;
        color: var(--color-muted);
        margin-bottom: 2rem;
        line-height: 1.75;
        opacity: 0;
        animation: fadeUp 0.6s ease forwards 0.3s;
      }

      .hero-title span { color: var(--color-ink); font-weight: 750; }

      .hero-cta {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        opacity: 0;
        animation: fadeUp 0.6s ease forwards 0.4s;
      }

      .hero-text-link {
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        color: var(--color-muted);
        font-size: 0.875rem;
        font-weight: 650;
        text-decoration: none;
      }

      .hero-text-link:hover { color: var(--color-ink-soft); }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        min-height: 44px;
        padding: 0 1.25rem;
        background: linear-gradient(135deg, var(--grad-start), var(--grad-mid));
        color: white;
        text-decoration: none;
        border-radius: 9999px;
        font-size: 0.875rem;
        font-weight: 750;
        transition: opacity 0.2s, transform 0.2s;
      }

      .btn-primary:hover { opacity: 0.85; transform: translateY(-2px); }

      .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        min-height: 44px;
        padding: 0 1.25rem;
        border: 1px solid var(--color-line);
        color: var(--color-muted);
        text-decoration: none;
        border-radius: 9999px;
        font-size: 0.875rem;
        font-weight: 650;
        transition: border-color 0.2s, color 0.2s, transform 0.2s;
      }

      .btn-secondary:hover { border-color: #cbd5e1; color: var(--color-ink-soft); transform: translateY(-2px); }

      .divider { height: 1px; background: var(--color-line-soft); }

      .section {
        padding: 4.5rem 0;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }

      .section.visible { opacity: 1; transform: translateY(0); }

      .section-label {
        font-size: 0.72rem;
        font-weight: 750;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--color-faint);
        margin-bottom: 0.75rem;
      }

      .section-title {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 3.5vw, 2rem);
        font-weight: 800;
        color: var(--color-ink);
        margin-bottom: 2rem;
        letter-spacing: 0;
      }

      .skills-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.5rem;
      }

      .skill-group {
        padding: 1.5rem;
        border: 1px solid #f1f5f9;
        border-radius: 12px;
        transition: border-color 0.2s, box-shadow 0.2s;
      }

      .skill-group:hover { border-color: #e2e8f0; box-shadow: 0 4px 20px rgba(0,0,0,0.04); }

      .skill-group-name {
        font-family: var(--font-display);
        font-size: 0.75rem;
        font-weight: 750;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 1rem;
        background: linear-gradient(135deg, var(--grad-start), var(--grad-end));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .skill-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

      .skill-tag {
        font-size: 0.8rem;
        padding: 0.25rem 0.75rem;
        border: 1px solid #e2e8f0;
        border-radius: 9999px;
        color: #64748b;
        background: #f8fafc;
        transition: border-color 0.2s, color 0.2s;
      }

      .skill-tag:hover { border-color: #cbd5e1; color: #334155; }

      /* ── PROJECTS ── */
      .projects-grid { display: flex; flex-direction: column; gap: 1rem; }

      .project-card {
        border: 1px solid #f1f5f9;
        border-radius: 16px;
        padding: 1.75rem;
        text-decoration: none;
        color: inherit;
        display: block;
        transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
      }

      .project-card:hover {
        border-color: #e2e8f0;
        box-shadow: 0 8px 30px rgba(0,0,0,0.06);
        transform: translateY(-3px);
      }

      /* 호버 오버레이 카드 */
      .project-card-hover {
        position: relative;
        border: 1px solid #dbeafe;
        border-radius: 16px;
        background: linear-gradient(135deg, #f8fafc 0%, #eff6ff 100%);
        overflow: hidden;
        transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
      }

      .project-card-hover:hover {
        border-color: #93c5fd;
        box-shadow: 0 8px 30px rgba(37,99,235,0.09);
        transform: translateY(-3px);
      }

      .project-card-content {
        padding: 1.75rem;
        transition: filter 0.25s, opacity 0.25s;
      }

      .project-card-hover:hover .project-card-content {
        filter: blur(1px);
        opacity: 0.35;
      }

      /* 오버레이 */
      .project-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        opacity: 0;
        transition: opacity 0.25s;
        padding: 1.75rem;
      }

      .project-card-hover:hover .project-overlay {
        opacity: 1;
      }

      .overlay-btn {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        padding: 1rem;
        border-radius: 14px;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
        transition: transform 0.15s, box-shadow 0.15s;
        text-align: center;
      }

      .overlay-btn:hover { transform: scale(1.04); }

      .overlay-btn.blog {
        background: white;
        color: #334155;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
      }

      .overlay-btn.service {
        background: linear-gradient(135deg, var(--grad-start), var(--grad-mid));
        color: white;
        box-shadow: 0 4px 16px rgba(37,99,235,0.24);
      }

      .overlay-btn-icon { font-size: 1.5rem; }

      .project-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
      }

      .project-emoji { font-size: 1.5rem; }

      .project-title {
        font-family: var(--font-display);
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--color-ink);
        letter-spacing: 0;
      }

      .project-desc {
        font-size: 0.875rem;
        color: #64748b;
        line-height: 1.7;
        margin-bottom: 1.25rem;
      }

      .project-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem; }

      .project-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 0.75rem;
      }

      .project-link {
        font-size: 0.8rem;
        color: #2563eb;
        font-weight: 600;
      }

      .project-badge {
        font-size: 0.7rem;
        padding: 0.2rem 0.6rem;
        background: #dcfce7;
        color: #16a34a;
        border-radius: 9999px;
        font-weight: 600;
        letter-spacing: 0.05em;
      }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @media (max-width: 640px) {
        main { padding: 0 0.95rem; }
        .hero {
          min-height: auto;
          padding: 2.35rem 0 2rem;
        }
        .hero-eyebrow {
          margin-bottom: 0.55rem;
          font-size: 0.66rem;
        }
        .hero-name {
          font-size: clamp(1.9rem, 9.8vw, 3rem);
          line-height: 1.06;
          margin-bottom: 0.72rem;
        }
        .hero-title {
          max-width: 21rem;
          margin-bottom: 1rem;
          font-size: 0.88rem;
          line-height: 1.58;
        }
        .hero-cta {
          display: grid;
          grid-template-columns: 1fr;
          gap: 0.35rem;
        }
        .btn-primary,
        .btn-secondary {
          justify-content: center;
          width: 100%;
        }
        .hero-text-link {
          justify-content: center;
          width: 100%;
          min-height: 36px;
          font-size: 0.8rem;
        }
        .section {
          padding: 2.15rem 0;
        }
        .section-title {
          font-size: 1.28rem;
          margin-bottom: 1.1rem;
        }
        .skills-grid { grid-template-columns: 1fr; }
        .skill-group,
        .project-card {
          padding: 1.1rem;
        }
        .project-card-content {
          padding: 0.95rem;
        }
        .project-title {
          font-size: 1rem;
        }
        .project-desc {
          font-size: 0.82rem;
          line-height: 1.6;
          margin-bottom: 0.9rem;
        }
        .skill-tag {
          font-size: 0.72rem;
          padding: 0.2rem 0.58rem;
        }
        .project-overlay {
          position: static;
          opacity: 1;
          padding: 0 0.95rem 0.95rem;
          gap: 0.6rem;
        }
        .project-card-hover:hover .project-card-content {
          filter: none;
          opacity: 1;
        }
        .overlay-btn { font-size: 0.75rem; padding: 0.75rem 0.5rem; }
      }
    </style>
  </head>
  <body>
    <Header />

    <main>
      <section class="hero">
        <p class="hero-eyebrow">jhwan.dev</p>
        <h1 class="hero-name">작은 서비스를<br />만들고 운영합니다.</h1>
        <p class="hero-title">
          <span>아이날씨와 홈서버를 직접 만들고 배포합니다.</span><br />
          쓰면서 고친 것들, 운영하면서 배운 것들을 조용히 기록합니다.
        </p>
        <div class="hero-cta">
          <a href="/blog/babyweather" class="btn-primary">BabyWeather 기록 보기 →</a>
          <a href="/blog" class="hero-text-link">전체 글 보기</a>
        </div>
      </section>

      <div class="divider"></div>

      <section class="section" id="projects">
        <p class="section-label">Operating Products</p>
        <h2 class="section-title">직접 만든 서비스</h2>
        <div class="projects-grid">

          <!-- babyweather - 호버 오버레이 카드 -->
          <div class="project-card-hover">
            <div class="project-card-content">
              <div class="project-header">
                <span class="project-emoji">☀️</span>
                <span class="project-title">아이날씨 (BabyWeather)</span>
              </div>
              <p class="project-desc">
                아이와 외출하기 좋은 시간을 빠르게 판단할 수 있도록 날씨·자외선·대기질을 하나의 점수로 묶은 모바일 웹앱.
                FastAPI, Docker, 라즈베리파이 환경에서 직접 운영하며 데이터 신뢰성, 캐시, 배포 자동화를 계속 개선 중.
              </p>
              <div class="project-tags">
                <span class="skill-tag">FastAPI</span>
                <span class="skill-tag">Docker</span>
                <span class="skill-tag">Python</span>
                <span class="skill-tag">Raspberry Pi</span>
                <span class="skill-tag">기상청 API</span>
                <span class="skill-tag">에어코리아 API</span>
                <span class="skill-tag">PWA</span>
              </div>
              <div class="project-footer">
                <span class="project-link">BabyWeather 기록 보기 →</span>
                <span class="project-badge">운영 중</span>
              </div>
            </div>
            <!-- 호버 오버레이 -->
            <div class="project-overlay">
              <a href="/blog/babyweather" class="overlay-btn blog">
                <span class="overlay-btn-icon">📝</span>
                기록 보기
              </a>
              <a href="https://babyweather.jhwan.dev" target="_blank" class="overlay-btn service">
                <span class="overlay-btn-icon">☀️</span>
                서비스 가기
              </a>
            </div>
          </div>

          <!-- 홈서버 -->
          <a href="/blog/homelab-setup" class="project-card">
            <div class="project-header">
              <span class="project-emoji">🖥️</span>
              <span class="project-title">홈서버 구축 (jhwan.dev)</span>
            </div>
            <p class="project-desc">
              라즈베리파이 4B 기반 홈서버. DDNS, Nginx Proxy Manager, Let's Encrypt SSL, Docker, GitHub Actions CI/CD까지 직접 구축해서 운영 중.
            </p>
            <div class="project-tags">
              <span class="skill-tag">Raspberry Pi</span>
              <span class="skill-tag">Docker</span>
              <span class="skill-tag">Nginx</span>
              <span class="skill-tag">GitHub Actions</span>
              <span class="skill-tag">Cloudflare</span>
            </div>
          </a>

        </div>
      </section>

      <div class="divider"></div>

      <section class="section" id="skills">
        <p class="section-label">Skills</p>
        <h2 class="section-title">기술 스택</h2>
        <div class="skills-grid">
          <div class="skill-group">
            <p class="skill-group-name">빅데이터 / ML</p>
            <div class="skill-tags">
              <span class="skill-tag">Python</span>
              <span class="skill-tag">PyTorch</span>
              <span class="skill-tag">Pandas</span>
              <span class="skill-tag">NumPy</span>
              <span class="skill-tag">Scikit-learn</span>
            </div>
          </div>
          <div class="skill-group">
            <p class="skill-group-name">인프라 / 백엔드</p>
            <div class="skill-tags">
              <span class="skill-tag">Docker</span>
              <span class="skill-tag">Linux</span>
              <span class="skill-tag">Nginx</span>
              <span class="skill-tag">FastAPI</span>
            </div>
          </div>
          <div class="skill-group">
            <p class="skill-group-name">프론트 / 모바일</p>
            <div class="skill-tags">
              <span class="skill-tag">Astro</span>
              <span class="skill-tag">Android</span>
              <span class="skill-tag">React</span>
            </div>
          </div>
        </div>
      </section>

    </main>

    <Footer />

    <script>
      const sections = document.querySelectorAll('.section');
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
        { threshold: 0.1 }
      );
      sections.forEach(s => observer.observe(s));
    </script>
  </body>
</html>
