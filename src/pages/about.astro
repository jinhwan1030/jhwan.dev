---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={`About | ${SITE_TITLE}`} description="Jinhwan Jung에 대하여" />
    <style>
      body {
        font-family: var(--font-sans);
        background: #ffffff;
        color: var(--color-ink);
      }

      main {
        max-width: var(--article-max);
        margin: 0 auto;
        padding: 4rem 1.5rem 6rem;
      }

      .page-label {
        font-size: 0.72rem;
        font-weight: 750;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--color-faint);
        margin-bottom: 0.75rem;
      }

      .page-title {
        font-family: var(--font-display);
        font-size: clamp(2.4rem, 8vw, 4rem);
        font-weight: 850;
        letter-spacing: 0;
        background: linear-gradient(135deg, var(--color-accent), var(--color-accent-strong), var(--color-accent-warm));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 2.75rem;
        line-height: 1.02;
      }

      .section {
        margin-bottom: 3.25rem;
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }

      .section.visible { opacity: 1; transform: translateY(0); }

      .section-label {
        font-size: 0.72rem;
        font-weight: 750;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--color-faint);
        margin-bottom: 1rem;
      }

      .prose {
        font-size: 1.02rem;
        line-height: 1.85;
        color: var(--color-ink-soft);
        font-weight: 450;
      }

      .prose p { margin-bottom: 1.25rem; }
      .prose p:last-child { margin-bottom: 0; }
      .prose strong { color: var(--color-ink); font-weight: 750; }

      .divider { height: 1px; background: var(--color-line-soft); margin: 3.25rem 0; }

      /* 타임라인 */
      .timeline { position: relative; padding-left: 1.5rem; }

      .timeline::before {
        content: '';
        position: absolute;
        left: 0; top: 8px; bottom: 8px;
        width: 1px;
        background: var(--color-line-soft);
      }

      .timeline-item { position: relative; margin-bottom: 2.35rem; }
      .timeline-item:last-child { margin-bottom: 0; }

      .timeline-item::before {
        content: '';
        position: absolute;
        left: -1.5rem; top: 8px;
        width: 7px; height: 7px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--color-accent), var(--color-accent-strong));
        transform: translateX(-3px);
      }

      .timeline-item.current::before {
        background: linear-gradient(135deg, #059669, var(--color-accent-warm));
        box-shadow: 0 0 0 3px #d1fae5;
      }

      .timeline-period {
        font-size: 0.72rem;
        color: var(--color-faint);
        letter-spacing: 0.05em;
        margin-bottom: 0.3rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .badge {
        font-size: 0.65rem;
        padding: 0.1rem 0.5rem;
        border-radius: 9999px;
        font-weight: 750;
        letter-spacing: 0.05em;
      }

      .badge.active {
        background: #dcfce7;
        color: #16a34a;
      }

      .badge.leave {
        background: #fef3c7;
        color: #d97706;
      }

      .timeline-title {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 800;
        color: var(--color-ink);
        margin-bottom: 0.4rem;
      }

      .timeline-sub {
        font-size: 0.8rem;
        color: var(--color-faint);
        margin-bottom: 0.5rem;
      }

      .timeline-desc {
        font-size: 0.875rem;
        color: var(--color-muted);
        line-height: 1.7;
      }

      .timeline-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        margin-top: 0.75rem;
      }

      /* 태그 */
      .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }

      .tag {
        font-size: 0.8rem;
        padding: 0.3rem 0.85rem;
        border: 1px solid var(--color-line);
        border-radius: 9999px;
        color: var(--color-muted);
        background: var(--color-surface-soft);
      }

      .tag.highlight {
        border-color: #ede9fe;
        color: var(--color-accent-strong);
        background: #faf5ff;
      }

      .tag.sm {
        font-size: 0.72rem;
        padding: 0.2rem 0.65rem;
      }

      /* 링크 카드 */
      .link-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        min-height: 52px;
        padding: 1rem 0;
        border-bottom: 1px solid var(--color-line-soft);
        text-decoration: none;
        color: var(--color-muted);
        font-size: 0.9rem;
        transition: color 0.2s;
      }

      .link-row:last-child { border-bottom: none; }
      .link-row:hover { color: var(--color-ink-soft); }

      .link-label {
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--color-faint);
        width: 80px;
        flex-shrink: 0;
        font-weight: 750;
      }

      .link-value { flex: 1; }

      .link-arrow {
        opacity: 0;
        transform: translateX(-4px);
        transition: opacity 0.2s, transform 0.2s;
        color: var(--color-faint);
      }

      .link-row:hover .link-arrow { opacity: 1; transform: translateX(0); }

      @media (max-width: 640px) {
        main {
          padding: 3rem 1rem 4.5rem;
        }
        .page-title {
          margin-bottom: 2rem;
        }
        .section {
          margin-bottom: 2.7rem;
        }
        .divider {
          margin: 2.7rem 0;
        }
        .prose {
          font-size: 1rem;
          line-height: 1.75;
        }
        .timeline {
          padding-left: 1.15rem;
        }
        .timeline-item::before {
          left: -1.15rem;
        }
        .timeline-period {
          flex-wrap: wrap;
          gap: 0.35rem;
        }
        .timeline-title {
          font-size: 0.98rem;
          line-height: 1.45;
        }
        .link-row {
          align-items: flex-start;
          gap: 0.75rem;
          min-height: 56px;
        }
        .link-label {
          width: 68px;
        }
        .link-value {
          word-break: break-word;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <p class="page-label">About</p>
      <h1 class="page-title">Jinhwan<br />Jung</h1>

      <!-- 자기소개 -->
      <section class="section">
        <p class="section-label">Intro</p>
        <div class="prose">
          <p>
            어릴 때부터 뭔가를 직접 만들고 고치는 걸 좋아했다. 남들이 사서 쓸 때 나는 뜯어보고 싶었고, 될 것 같으면 일단 해봤다.
          </p>
          <p>
            <strong>헤킨토시</strong>를 올려보고, <strong>Xpenology</strong>로 NAS를 만들어보고, 라즈베리파이에 온갖 걸 올려보고. 잘 안 되면 더 찾아봤고, 되면 또 다른 걸 시도했다.
          </p>
          <p>
            임베디드 개발로 시작해서 기상 데이터, 앱 기획, 백엔드 개발까지 넘어왔다. 육아휴직 중에는 아이와 외출하기 전의 반복적인 고민을 줄이기 위해 <strong>아이날씨(BabyWeather)</strong>를 만들었고, 지금은 직접 배포하고 운영하면서 데이터 신뢰성, 사용자 경험, 배포 자동화까지 계속 다듬고 있다.
          </p>
          <p>
            기획도 하고 개발도 하는 사람. 문제를 발견하고, 작게 만들고, 직접 배포한 뒤 운영하면서 개선하는 흐름을 끝까지 가져가는 것이 강점이라고 생각한다.
          </p>
        </div>
      </section>

      <div class="divider"></div>

      <!-- 경력 타임라인 -->
      <section class="section">
        <p class="section-label">Experience</p>
        <div class="timeline">

          <div class="timeline-item current">
            <p class="timeline-period">
              2026.01 ~ 현재
              <span class="badge active">재직 중</span>
            </p>
            <p class="timeline-title">기상 데이터 · 앱 개발 · 서비스 기획</p>
            <p class="timeline-sub">기상 전문 기업</p>
            <p class="timeline-desc">기상 데이터 가공 및 API 연동, 모바일 앱 개발 기획, 서비스 운영. 복직 후 개발/기획 역할 병행.</p>
            <div class="timeline-tags">
              <span class="tag sm highlight">Python</span>
              <span class="tag sm highlight">FastAPI</span>
              <span class="tag sm">Flutter</span>
              <span class="tag sm">Swift</span>
              <span class="tag sm">기상 API</span>
            </div>
          </div>

          <div class="timeline-item">
            <p class="timeline-period">
              2024.06 ~ 2025.12
              <span class="badge leave">육아휴직</span>
            </p>
            <p class="timeline-title">개인 프로젝트 · 홈랩</p>
            <p class="timeline-desc">BabyWeather 웹앱 개발 및 운영. 라즈베리파이 홈서버, Proxmox NAS, WireGuard VPN, CI/CD 파이프라인을 구성하며 개인 서비스 운영 환경을 직접 구축.</p>
            <div class="timeline-tags">
              <span class="tag sm highlight">FastAPI</span>
              <span class="tag sm highlight">Docker</span>
              <span class="tag sm">Raspberry Pi</span>
              <span class="tag sm">Proxmox</span>
              <span class="tag sm">Nginx</span>
            </div>
          </div>

          <div class="timeline-item">
            <p class="timeline-period">2023.03 ~ 2024.06</p>
            <p class="timeline-title">기상 데이터 · 앱 개발 · 서비스 기획</p>
            <p class="timeline-sub">기상 전문 기업</p>
            <p class="timeline-desc">기상청 공공데이터 수집 및 가공, 모바일 앱(Flutter/Swift) 개발 기획, 서비스 운영 및 사용자 피드백 반영.</p>
            <div class="timeline-tags">
              <span class="tag sm">Flutter</span>
              <span class="tag sm">Swift</span>
              <span class="tag sm">기상 API</span>
              <span class="tag sm">서비스 기획</span>
            </div>
          </div>

          <div class="timeline-item">
            <p class="timeline-period">2021.05 ~ 2022.08</p>
            <p class="timeline-title">임베디드 Linux · 자율주행 진단통신</p>
            <p class="timeline-desc">임베디드 Linux 환경에서 자율주행 차량 진단 및 통신 시스템 개발. CAN 통신, 차량 진단 프로토콜(UDS) 연동.</p>
            <div class="timeline-tags">
              <span class="tag sm highlight">Embedded Linux</span>
              <span class="tag sm">C/C++</span>
              <span class="tag sm">CAN</span>
              <span class="tag sm">UDS</span>
              <span class="tag sm">자율주행</span>
            </div>
          </div>

        </div>
      </section>

      <div class="divider"></div>

      <!-- 프로젝트 -->
      <section class="section">
        <p class="section-label">Projects</p>
        <div class="timeline">
          <div class="timeline-item current">
            <p class="timeline-period">
              2026.05 ~ 현재
              <span class="badge active">운영 중</span>
            </p>
            <p class="timeline-title">아이날씨 (BabyWeather)</p>
            <p class="timeline-desc">기상청·에어코리아·카카오 API를 조합해 아이와 외출하기 좋은 날씨인지 100점 만점으로 보여주는 웹앱. FastAPI + Docker + 라즈베리파이로 직접 서비스 운영. PWA 지원.</p>
            <div class="timeline-tags">
              <span class="tag sm highlight">FastAPI</span>
              <span class="tag sm highlight">Docker</span>
              <span class="tag sm">Python</span>
              <span class="tag sm">Raspberry Pi</span>
              <span class="tag sm">PWA</span>
              <span class="tag sm">기상청 API</span>
            </div>
          </div>
          <div class="timeline-item current">
            <p class="timeline-period">
              2026 ~ 현재
              <span class="badge active">운영 중</span>
            </p>
            <p class="timeline-title">jhwan.dev 홈서버</p>
            <p class="timeline-desc">라즈베리파이 4B 기반 홈서버. DDNS, Nginx Proxy Manager, Let's Encrypt SSL, Docker, cron 기반 자동배포까지 직접 구축.</p>
            <div class="timeline-tags">
              <span class="tag sm">Raspberry Pi</span>
              <span class="tag sm">Docker</span>
              <span class="tag sm">Nginx</span>
              <span class="tag sm">Cloudflare</span>
              <span class="tag sm">Astro</span>
            </div>
          </div>
        </div>
      </section>

      <div class="divider"></div>

      <!-- 관심사 -->
      <section class="section">
        <p class="section-label">Interests</p>
        <div class="prose">
          <p>
            홈랩 구축, 자작 프로젝트, 그리고 작지만 실제로 운영되는 서비스를 계속 만들어보는 것에 관심이 있다. Android와 React도 배우면서, 제품 경험을 더 풍부하게 만드는 프론트엔드 역량을 키우고 있다.
          </p>
        </div>
        <div class="tags">
          <span class="tag highlight">홈랩</span>
          <span class="tag highlight">ML/AI</span>
          <span class="tag">Android</span>
          <span class="tag">React</span>
          <span class="tag">임베디드</span>
          <span class="tag">자작 프로젝트</span>
          <span class="tag">데스크테리어</span>
        </div>
      </section>

      <div class="divider"></div>

      <!-- 기술 스택 -->
      <section class="section">
        <p class="section-label">Stack</p>
        <div class="tags">
          <span class="tag highlight">Python</span>
          <span class="tag highlight">FastAPI</span>
          <span class="tag highlight">Docker</span>
          <span class="tag highlight">PyTorch</span>
          <span class="tag">Pandas</span>
          <span class="tag">NumPy</span>
          <span class="tag">Scikit-learn</span>
          <span class="tag">Flutter</span>
          <span class="tag">Swift</span>
          <span class="tag">Linux</span>
          <span class="tag">Nginx</span>
          <span class="tag">Astro</span>
        </div>
      </section>

      <div class="divider"></div>

      <!-- 링크 -->
      <section class="section">
        <p class="section-label">Links</p>
        <div style="margin-top: 0.5rem;">
          <a href="https://github.com/jinhwan1030" target="_blank" rel="noopener noreferrer" class="link-row">
            <span class="link-label">GitHub</span>
            <span class="link-value">github.com/jinhwan1030</span>
            <span class="link-arrow">→</span>
          </a>
          <a href="https://babyweather.jhwan.dev" target="_blank" rel="noopener noreferrer" class="link-row">
            <span class="link-label">Project</span>
            <span class="link-value">babyweather.jhwan.dev</span>
            <span class="link-arrow">→</span>
          </a>
          <a href="mailto:saewoo_@naver.com" class="link-row">
            <span class="link-label">Email</span>
            <span class="link-value">saewoo_@naver.com</span>
            <span class="link-arrow">→</span>
          </a>
        </div>
      </section>

    </main>
    <Footer />

    <script>
      const sections = document.querySelectorAll('.section');
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
        { threshold: 0.1 }
      );
      sections.forEach(s => observer.observe(s));
    </script>
  </body>
</html>
